# Explicitly choose storage. Use memory only for local development/tests.
STORAGE_BACKEND=memory
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Required and at least 32 characters in production.
DEMO_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
# Only use when developing locally without OpenAI credentials.
ENABLE_LOCAL_AI_FALLBACK=true
